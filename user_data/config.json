{
  "trading_mode": "futures",
  "margin_mode": "isolated",

  "max_open_trades": 3,
  "stake_currency": "USDC",
  "stake_amount": "unlimited",
  "tradable_balance_ratio": 0.99,
  "dry_run": true,
  "dry_run_wallet": 300,
  "fee": 0.00045,

  "cancel_open_orders_on_exit": true,

  "exchange": {
    "name": "hyperliquid",
    "key": "${HYPERLIQUID_API_KEY}",
    "secret": "${HYPERLIQUID_API_SECRET}",
    "ccxt_config": {},
    "ccxt_async_config": {},
    "pair_whitelist": ["BTC/USDC:USDC", "HYPE/USDC:USDC", "ENA/USDC:USDC"],

    "pair_blacklist": []
  },

  "entry_pricing": {
    "price_side": "other",
    "use_order_book": true,
    "order_book_top": 1,
    "price_last_balance": 0.0,
    "check_depth_of_market": {
      "enabled": false,
      "bids_to_ask_delta": 1
    }
  },

  "exit_pricing": {
    "price_side": "other",
    "use_order_book": true,
    "order_book_top": 1
  },

  "order_types": {
    "entry": "limit",
    "exit": "limit",
    "stoploss": "market",
    "stoploss_on_exchange": false
  },

  "pairlists": [
    {
      "method": "StaticPairList"
    }
  ],

  "api_server": {
    "enabled": true,
    "listen_ip_address": "0.0.0.0",
    "listen_port": 8080,
    "verbosity": "error",
    "enable_openapi": false,
    "jwt_secret_key": "changeme",
    "ws_token": "changeme_ws",
    "CORS_origins": [],
    "username": "freqtrade",
    "password": "freqtrade"
  }
}
